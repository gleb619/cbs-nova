root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,kt,kts}]
indent_style = space
indent_size = 2
continuation_indent_size = 4
max_line_length = 100

[*.java]
ij_java_imports_layout = *, |, javax.**, |, java.**
ij_java_class_count_to_use_import_on_demand = 999
ij_java_names_count_to_use_import_on_demand = 999

[*.{kt,kts}]
ij_kotlin_imports_layout = *, |, javax.**, |, java.**
ij_kotlin_class_count_to_use_import_on_demand = 999
ij_kotlin_name_count_to_use_import_on_demand = 999
ktfmt_enabled = true
ktlint_standard_backing-property-naming = disabled


[*.gradle]
indent_style = space
indent_size = 2

[*.{xml,html}]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.properties]
indent_style = space
indent_size = 2

[{Makefile,*.mk}]
indent_style = tab
indent_size = 4

[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf