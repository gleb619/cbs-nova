<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
  "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
  "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
  <module name="SuppressWarningsFilter"/>
  <module name="SuppressionFilter">
    <property name="file" value="${suppressionsFile}"/>
  </module>
  <module name="NewlineAtEndOfFile">
    <property name="lineSeparator" value="lf"/>
  </module>
  <module name="RegexpSingleline">
    <property name="format" value="\s+$"/>
    <property name="minimum" value="0"/>
    <property name="maximum" value="0"/>
    <property name="message" value="Line has trailing whitespace."/>
  </module>
  <module name="FileTabCharacter">
    <property name="eachLine" value="true"/>
  </module>

  <!-- Newline at end of file -->
  <module name="TreeWalker">
    <module name="SuppressWarningsHolder"/>
    <module name="SuppressionCommentFilter"/>

    <!-- IMPORTS -->
    <module name="UnusedImports"/>
    <module name="RedundantImport"/>
    <module name="IllegalImport"/>
    <module name="AvoidStarImport"/>
    <module name="ImportOrder">
      <property name="groups" value="*,/java\./"/>
      <property name="ordered" value="true"/>
      <property name="separated" value="true"/>
      <property name="option" value="top"/>
      <property name="sortStaticImportsAlphabetically" value="true"/>
    </module>

    <!-- INDENTATION (2 spaces) -->
    <module name="Indentation">
      <property name="basicOffset" value="2"/>
      <property name="braceAdjustment" value="0"/>
      <property name="caseIndent" value="2"/>
      <property name="throwsIndent" value="4"/>
      <property name="lineWrappingIndentation" value="4"/>
      <property name="arrayInitIndent" value="2"/>
    </module>

    <!-- JAVADOC (relaxed for tests) -->
    <!-- Javadoc not required on test methods/classes/fields -->
    <module name="JavadocStyle">
      <property name="checkFirstSentence" value="true"/>
    </module>

    <!-- WHITESPACE -->
    <module name="WhitespaceAround">
      <property name="allowEmptyConstructors" value="true"/>
      <property name="allowEmptyMethods" value="true"/>
      <property name="allowEmptyTypes" value="true"/>
      <property name="allowEmptyLoops" value="true"/>
    </module>
    <module name="WhitespaceAfter"/>
    <module name="NoWhitespaceBefore"/>
    <module name="GenericWhitespace"/>
    <module name="MethodParamPad"/>
    <module name="ParenPad"/>
    <module name="TypecastParenPad"/>

    <!-- BRACES -->
    <module name="NeedBraces"/>
    <module name="LeftCurly"/>
    <module name="RightCurly"/>

    <!-- NAMING -->
    <module name="PackageName">
      <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
    </module>
    <module name="TypeName"/>
    <module name="MemberName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>
    <module name="ParameterName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>
    <module name="LocalVariableName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>
    <module name="ConstantName"/>

    <!-- Test methods allow underscores: e.g. should_doX_when_Y() -->
    <module name="MethodName">
      <property name="format" value="^[a-z][a-zA-Z0-9_]*$"/>
    </module>

    <!-- MODIFIERS -->
    <module name="ModifierOrder"/>
    <!-- RedundantModifier omitted: test frameworks often need explicit modifiers -->

    <!-- MISC -->
    <module name="OneTopLevelClass"/>
    <module name="OuterTypeFilename"/>
    <module name="MultipleVariableDeclarations"/>
    <module name="ArrayTypeStyle"/>
    <module name="UpperEll"/>
    <module name="FallThrough"/>
    <module name="AnnotationLocation">
      <property name="allowSamelineMultipleAnnotations" value="false"/>
      <property name="allowSamelineSingleParameterlessAnnotation" value="false"/>
      <property name="allowSamelineParameterizedAnnotation" value="false"/>
    </module>

    <!-- EmptyLineSeparator omitted: test classes are more loosely structured -->
    <!-- NoLineWrap omitted: long assertion chains are common in tests -->

    <!-- Allow empty catch blocks for expected exceptions -->
    <module name="EmptyCatchBlock">
      <property name="exceptionVariableName" value="expected|ignored|ignore"/>
    </module>

  </module>

  <!-- No trailing whitespace -->
  <property name="severity" value="error"/>

  <!-- Tab characters not allowed -->
  <property name="fileExtensions" value="java"/>

  <property name="charset" value="UTF-8"/>
</module>